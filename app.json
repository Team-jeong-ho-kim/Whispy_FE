{
  "expo": {
    "name": "Whispy_v1",
    "slug": "Whispy_v1",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "whispyv1",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app uses audio playback.",
        "UIBackgroundModes": [
          "audio",
          "audio"
        ],
        "AVAudioSessionCategoryPlayback": true,
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.whispy.app"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "permissions": [
        "RECORD_AUDIO",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK",
        "ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "assetBundlePatterns": [
      "assets/fonts/*"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d5db8d29-109b-412b-9a1d-9d7f14456c32"
      }
    }
  }
}
